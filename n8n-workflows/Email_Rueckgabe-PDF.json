      "parameters": {
        "jsCode": "const input = $input.first().json\nconst body = input.body || input\n\n// Dateiname sanitizen (Umlaute entfernen)\nconst rawFilename = body.pdf_filename || 'rueckgabe.pdf'\nconst sanitizedFilename = rawFilename\n  .replace(/Ü/g, 'Ue').replace(/ü/g, 'ue')\n  .replace(/Ö/g, 'Oe').replace(/ö/g, 'oe')\n  .replace(/Ä/g, 'Ae').replace(/ä/g, 'ae')\n  .replace(/ß/g, 'ss')\n  .replace(/\\s+/g, '_')\n\nconst protocolBuffer = Buffer.from(body.pdf_base64, 'base64')\nconst protocolBinary = await this.helpers.prepareBinaryData(\n  protocolBuffer,\n  sanitizedFilename,\n  'application/pdf'\n)\n\nreturn [{\n  json: {\n    customer_email: body.customer_email,\n    customer_name: body.customer_name,\n    rental_number: body.rental_number,\n    rental_id: body.rental_id,\n    protocol_type: body.protocol_type,\n    vehicle: body.vehicle,\n    pdf_filename: sanitizedFilename,\n    pdf_storage_url: `https://supabase.benneuendorf.com/storage/v1/object/public/orcacampers_documents/protocols/${sanitizedFilename}`\n  },\n  binary: {\n    protocol_pdf: protocolBinary\n  }\n}]"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 0],
      "id": "a1b2c3d4-0003-4000-8000-000000000003",
      "name": "Code in JavaScript"
